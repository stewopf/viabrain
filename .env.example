MONGODB_URI=mongodb://127.0.0.1:27017/viabrain
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
CURSOR_API_KEY=
# Local SDK sandbox (not supported on many AWS images). Default: on in dev, off for npm start.
# CURSOR_SANDBOX_ENABLED=false
GH_TOKEN=
REPOS_ROOT=./repos
PORT=4000
# Public URL of the app (scheme + host + port). Use https:// when TLS is enabled.
CLIENT_ORIGIN=http://localhost:4000
# Optional: force Secure cookies (true) or allow HTTP cookies (false).
# Defaults from CLIENT_ORIGIN (https → Secure cookies).
# COOKIE_SECURE=false
# Vite allowedHosts is enabled for dev/remote access (see client/vite.config.ts).
CRON_SYNC=0 2 * * *
CURSOR_HOME=./.cursor-home

# Okta SSO (optional — enables "Sign in with Okta" when both are set)
OKTA_ORG_URL=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
# Must match an Okta app Sign-in redirect URI (same origin as the app).
OKTA_REDIRECT_URI=http://localhost:4000/api/auth/okta/callback
OKTA_POST_LOGIN_REDIRECT=http://localhost:4000/
OKTA_SCOPES=openid profile email
